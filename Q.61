Write a program to Find missing number in 
array

#include <stdio.h>

int main()
{
    int arr[100], n, i;
    int sum = 0, totalSum, missing;

    printf("Enter size of array: ");
    scanf("%d", &n);

    printf("Enter %d elements (from 1 to %d with one missing):\n", n - 1, n);

    for(i = 0; i < n - 1; i++)
    {
        scanf("%d", &arr[i]);
        sum += arr[i];
    }

    totalSum = n * (n + 1) / 2;

    missing = totalSum - sum;

    printf("Missing number = %d", missing);

    return 0;
}
