Write a program to Create ticket booking 
system.

#include <stdio.h>

int main()
{
    char name[50];
    int tickets;
    float price = 250.0, totalAmount;

    printf("Enter Passenger Name: ");
    scanf("%s", name);

    printf("Enter Number of Tickets: ");
    scanf("%d", &tickets);

    totalAmount = tickets * price;

    printf("\n----- Ticket Details -----\n");
    printf("Passenger Name : %s\n", name);
    printf("Tickets        : %d\n", tickets);
    printf("Price/Ticket   : %.2f\n", price);
    printf("Total Amount   : %.2f\n", totalAmount);

    return 0;
}
